{
  "name": "fns-cli",
  "dockerComposeFile": "compose.yml",
  "service": "app",
  "workspaceFolder": "/app",

  "mounts": [
    // cli
    "source=${localEnv:HOME}/.fns-cli/container.bash_profile,target=/home/vscode/fns-cli.bash_profile,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.bash_history,target=/home/vscode/.bash_history,type=bind,consistency=cached",
    // devtools
    "source=gemini,target=/home/vscode/.gemini,type=volume",
    // source code
    "source=${localWorkspaceFolder},target=/app,type=bind,consistency=cached"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "EditorConfig.EditorConfig",
        "esbenp.prettier-vscode",
        "mkhl.shfmt",
        "eamodio.gitlens",
        "github.vscode-github-actions"
      ]
    }
  },

  "postCreateCommand": "bash .devcontainer/install.sh"
}
